# uFawkesRes Environment Variables
# Copy this file to .env and set real values before starting the stack.
# The .env file is gitignored — never commit it.

# PostgreSQL (shared database for Authelia SSO)
POSTGRES_PASSWORD=changeme
POSTGRES_USER=fawkes
POSTGRES_DB=fawkes

# Authelia SSO secrets
AUTHELIA_JWT_SECRET=changeme
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme
AUTHELIA_SESSION_SECRET=changeme

# Valkey cache password
VALKEY_PASSWORD=changeme
